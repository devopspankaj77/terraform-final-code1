# =============================================================================
# Dev Environment - Example tfvars (copy to dev.tfvars and set values)
# Naming: ICR-<nnn>-Azure-<INT|CLT>-<ResourceType>-<Workload> (see docs/NAMING_CONVENTION.md)
# =============================================================================

# Company-mandatory tags
created_by       = "Pankaj"
created_date     = "2026-03-11"
environment     = "dev"
requester        = "Application Team"
ticket_reference = "INC-12345"
project_name     = "Banking-App"

# Naming
name_prefix   = "ICR-002"
project_type  = "INT"
workload      = "Bank-Dev"
location      = "centralindia"

# Security: restrict jump RDP/SSH (set via TF_VAR_jump_rdp_source_cidr / TF_VAR_jump_ssh_source_cidr in prod)
# jump_rdp_source_cidr = "YOUR_IP/32"
# jump_ssh_source_cidr = "YOUR_IP/32"

# -----------------------------------------------------------------------------
# Resource groups
# -----------------------------------------------------------------------------
resource_groups = {
  main = {
    name     = "ICR-002-Azure-INT-RG-Bank-Dev"
    location = "centralindia"
    create_lock = false
    tags     = {}
  }
}

# -----------------------------------------------------------------------------
# VNets (optional)
# -----------------------------------------------------------------------------
vnets = {
  main = {
    name                = "ICR-002-Azure-INT-VNet-Bank-Dev"
    resource_group_name = "ICR-002-Azure-INT-RG-Bank-Dev"
    location            = "centralindia"
    address_space       = ["10.0.0.0/16"]
    dns_servers         = []
    create_nsg          = true
    nsg_per_subnet      = false
    create_private_endpoint_subnet = true
    private_endpoint_subnet_prefix = "10.0.254.0/24"
    subnets = {
      web = {
        name             = "snet-web"
        address_prefixes = ["10.0.1.0/24"]
        allow_private_endpoint = false
      }
      app = {
        name             = "snet-app"
        address_prefixes = ["10.0.2.0/24"]
      }
      data = {
        name             = "snet-data"
        address_prefixes = ["10.0.3.0/24"]
      }
    }
    nsg_rules = {
      allow_ssh = {
        name                   = "AllowSSH"
        priority               = 100
        direction              = "Inbound"
        access                 = "Allow"
        protocol               = "Tcp"
        source_port_range      = "*"
        destination_port_range = "22"
        source_address_prefix  = "VirtualNetwork"
        destination_address_prefix = "*"
      }
      allow_rdp = {
        name                   = "AllowRDP"
        priority               = 110
        direction              = "Inbound"
        access                 = "Allow"
        protocol               = "Tcp"
        source_port_range      = "*"
        destination_port_range = "3389"
        source_address_prefix  = "VirtualNetwork"
        destination_address_prefix = "*"
      }
    }
    tags = {}
  }
}

